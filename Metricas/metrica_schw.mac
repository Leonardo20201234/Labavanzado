/* ============================================
   MÉTRICA DE SCHWARZSCHILD
   ============================================ */

declare(m, real)$
rs: 2 * m$

coords: [q0, q1, q2, q3]$

g: matrix(
  [-(1 - rs/q1),        0,         0,                  0],
  [0,       1/(1-rs/q1),           0,                  0],
  [0,                  0,       q1^2,                  0],
  [0,                  0,          0,  q1^2*sin(q2)^2]
)$